# Server Configuration

PORT=3001

NODE_ENV=development



# Database Configuration

MONGODB_URI=your_mongodb_connection_string_here

# For local development: mongodb://localhost:27017/roadalert

# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/roadalert



# JWT Configuration

JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

JWT_EXPIRE=7d



# Admin JWT Configuration

ADMIN_JWT_SECRET=your_admin_jwt_secret_key_here_make_it_different_from_user_jwt

ADMIN_JWT_EXPIRE=7d



# Rate Limiting

RATE_LIMIT_WINDOW=15

RATE_LIMIT_MAX=100







# Cloudinary Configuration (Required for image storage)

# Sign up at https://cloudinary.com

# Get these values from your Cloudinary Dashboard -> Account Details

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here

CLOUDINARY_API_KEY=your_cloudinary_api_key_here

CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here



# Frontend URLs (for CORS)

FRONTEND_URL=http://localhost:5173

ADMIN_FRONTEND_URL=http://localhost:5174



# Firebase Cloud Messaging (FCM) Configuration

# Get these from Firebase Console -> Project Settings -> Service Accounts

# Generate a private key and use the values from the JSON file

FIREBASE_PROJECT_ID=your_firebase_project_id_here

FIREBASE_PRIVATE_KEY=your_firebase_private_key_here_replace_newlines_with_n

FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here

FIREBASE_DATABASE_URL=your_firebase_database_url_here



# FCM Configuration

# Set to false to disable FCM (fallback to polling)

FCM_ENABLED=true



# Firebase Cloud Messaging (FCM) Configuration

# Required for push notifications on mobile devices

# Get these values from Firebase Console → Project Settings → Service Accounts → Generate New Private Key

# The JSON file will contain project_id, client_email, and private_key

FIREBASE_PROJECT_ID=your-firebase-project-id

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com



# FCM Toggle (set to 'false' to disable push notifications and fall back to polling)

FCM_ENABLED=true

