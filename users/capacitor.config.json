{
  "appId": "com.bantaydalan.app",
  "appName": "BantayDalan",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "https://roadalert-backend-xze4.onrender.com/*",
      "https://*.onrender.com/*",
      "https://accounts.google.com/*",
      "https://*.googleapis.com/*",
      "https://*.cloudinary.com/*"
    ]
  },
  "plugins": {
    "Camera": {
      "permissions": [
        "camera",
        "photos"
      ]
    },
    "Geolocation": {
      "permissions": [
        "location",
        "coarseLocation"
      ]
    },
    "Network": {
      "permissions": [
        "internet",
        "network-state"
      ]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#488AFF"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#ffffff",
      "showSpinner": true,
      "spinnerColor": "#007bff"
    }
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#ffffff"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#ffffff"
  }
}
