{
  "appId": "com.bantaydalan.app",
  "appName": "BantayDalan",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "roadalert-backend-xze4.onrender.com",
      "*.onrender.com"
    ]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "Camera": {
      "permissions": [
        "camera",
        "photos"
      ]
    },
    "Geolocation": {
      "permissions": [
        "location"
      ]
    },
    "Network": {
      "permissions": [
        "internet",
        "network-state"
      ]
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  }
}